---
const { head } = Astro.locals.starlightRoute;
const pathname = Astro.url.pathname;
const version = pathname.startsWith('/v5/') || pathname === '/v5' ? 'v5' : 'v4';

function textFromHeadMeta(name: 'description' | 'twitter:card' | 'twitter:image') {
  const entry = head.find(({ tag, attrs }) => tag === 'meta' && attrs?.name === name);
  return typeof entry?.attrs?.content === 'string' ? entry.attrs.content : '';
}

function textFromHeadProperty(property: 'og:title' | 'og:description') {
  const entry = head.find(({ tag, attrs }) => tag === 'meta' && attrs?.property === property);
  return typeof entry?.attrs?.content === 'string' ? entry.attrs.content : '';
}

function titleCaseSlug(slug: string) {
  return slug
    .split('-')
    .filter(Boolean)
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

function sectionFromPath(pathname: string) {
  const parts = pathname.replace(/^\/+|\/+$/g, '').split('/').filter(Boolean);
  if (parts.length <= 2) return '';
  return titleCaseSlug(parts[1]);
}

function buildSeoTitle(pageTitle: string) {
  const section = sectionFromPath(pathname);
  if (pageTitle === 'Overview') {
    return `Noctalia ${version} documentation overview | Noctalia Docs`;
  }
  if (section) {
    return `${pageTitle} ${section.toLowerCase()} for Noctalia ${version} | Noctalia Docs`;
  }
  return `${pageTitle} for Noctalia ${version} | Noctalia Docs`;
}

function buildSeoDescription(pageTitle: string, description: string) {
  const clean = description || 'Noctalia documentation and guides.';
  if (clean.length >= 110) return clean;
  const subject = pageTitle === 'Overview' ? `Noctalia ${version}` : `${pageTitle} in Noctalia ${version}`;
  return `${clean} Learn setup details, recommended options, and practical guidance for ${subject}.`;
}

function ogImagePathForRoute(pathname: string) {
  const clean = pathname.split(/[?#]/, 1)[0] || '/';
  const withoutTrailingSlash = clean.length > 1 ? clean.replace(/\/+$/, '') : clean;
  if (withoutTrailingSlash === '/') return '/og/docs.webp';
  return `/og/docs/${withoutTrailingSlash.replace(/^\/+/, '')}.webp`;
}

const pageTitle = textFromHeadProperty('og:title') || 'Noctalia';
const seoTitle = buildSeoTitle(pageTitle);
const seoDescription = buildSeoDescription(pageTitle, textFromHeadProperty('og:description') || textFromHeadMeta('description'));
const ogImagePath = ogImagePathForRoute(pathname);
const ogImageUrl = new URL(ogImagePath, Astro.site ?? Astro.url.origin).href;
const ogImageAlt = 'Noctalia documentation preview';

const enhancedHead = head.map((entry) => {
  if (entry.tag === 'title') return { ...entry, content: seoTitle };
  if (entry.tag === 'meta' && entry.attrs?.name === 'description') {
    return { ...entry, attrs: { ...entry.attrs, content: seoDescription } };
  }
  if (entry.tag === 'meta' && entry.attrs?.property === 'og:title') {
    return { ...entry, attrs: { ...entry.attrs, content: seoTitle } };
  }
  if (entry.tag === 'meta' && entry.attrs?.property === 'og:description') {
    return { ...entry, attrs: { ...entry.attrs, content: seoDescription } };
  }
  return entry;
});
---

{enhancedHead.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
<slot />
<meta data-pagefind-filter={`version:${version}`} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/webp" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta name="twitter:title" content={seoTitle} />
<meta name="twitter:description" content={seoDescription} />
<meta name="twitter:image" content={ogImageUrl} />
