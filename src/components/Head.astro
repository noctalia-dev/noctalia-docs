---
import Default from '@astrojs/starlight/components/Head.astro';

const pathname = Astro.url.pathname;
const version = pathname.startsWith('/v5/') || pathname === '/v5' ? 'v5' : 'v4';

function ogImagePathForRoute(pathname: string) {
  const clean = pathname.split(/[?#]/, 1)[0] || '/';
  const withoutTrailingSlash = clean.length > 1 ? clean.replace(/\/+$/, '') : clean;
  if (withoutTrailingSlash === '/') return '/og/docs.webp';
  return `/og/docs/${withoutTrailingSlash.replace(/^\/+/, '')}.webp`;
}

const ogImagePath = ogImagePathForRoute(pathname);
const ogImageUrl = new URL(ogImagePath, Astro.site ?? Astro.url.origin).href;
const ogImageAlt = 'Noctalia documentation preview';
---

<Default {...Astro.props}><slot /></Default>
<meta data-pagefind-filter={`version:${version}`} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/webp" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta name="twitter:image" content={ogImageUrl} />
