---
interface Props {
  question: string;
  id?: string;
}

const { question, id } = Astro.props;
const slug =
  id ??
  question
    .toLowerCase()
    .replace(/[^\w\s-]/g, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/(^-|-$)/g, "");
---

<details class="faq-item" id={slug}>
  <summary>
    <strong>{question}</strong>
    <a href={`#${slug}`} class="faq-anchor" aria-label={`Link to "${question}"`}><svg width="16" height="16" viewBox="0 0 24 24"><path fill="currentcolor" d="m12.11 15.39-3.88 3.88a2.52 2.52 0 0 1-3.5 0 2.47 2.47 0 0 1 0-3.5l3.88-3.88a1 1 0 0 0-1.42-1.42l-3.88 3.89a4.48 4.48 0 0 0 6.33 6.33l3.89-3.88a1 1 0 1 0-1.42-1.42Zm8.58-12.08a4.49 4.49 0 0 0-6.33 0l-3.89 3.88a1 1 0 0 0 1.42 1.42l3.88-3.88a2.52 2.52 0 0 1 3.5 0 2.47 2.47 0 0 1 0 3.5l-3.88 3.88a1 1 0 1 0 1.42 1.42l3.88-3.89a4.49 4.49 0 0 0 0-6.33ZM8.83 15.17a1 1 0 0 0 1.1.22 1 1 0 0 0 .32-.22l4.92-4.92a1 1 0 0 0-1.42-1.42l-4.92 4.92a1 1 0 0 0 0 1.42Z"/></svg></a>
  </summary>
  <div class="faq-answer">
    <slot />
  </div>
</details>

<script>
  function openHashTarget() {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    const target = document.getElementById(hash);
    if (target instanceof HTMLDetailsElement && target.classList.contains("faq-item")) {
      target.open = true;
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function initFaqAnchors() {
    document.querySelectorAll<HTMLAnchorElement>(".faq-item .faq-anchor").forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        e.stopPropagation();
      });
    });
  }

  openHashTarget();
  initFaqAnchors();
  window.addEventListener("hashchange", openHashTarget);
  document.addEventListener("astro:page-load", () => {
    openHashTarget();
    initFaqAnchors();
  });
</script>
