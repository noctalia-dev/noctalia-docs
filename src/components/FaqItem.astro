---
interface Props {
  question: string;
  id?: string;
}

const { question, id } = Astro.props;
const slug =
  id ??
  question
    .toLowerCase()
    .replace(/[^\w\s-]/g, "")
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-")
    .replace(/(^-|-$)/g, "");
---

<details class="faq-item" id={slug}>
  <summary>
    <strong>{question}</strong>
    <a href={`#${slug}`} class="faq-anchor" aria-label={`Link to "${question}"`}><svg width="16" height="16" viewBox="0 0 24 24"><path fill="currentcolor" d="m12.11 15.39-3.88 3.88a2.52 2.52 0 0 1-3.5 0 2.47 2.47 0 0 1 0-3.5l3.88-3.88a1 1 0 0 0-1.42-1.42l-3.88 3.89a4.48 4.48 0 0 0 6.33 6.33l3.89-3.88a1 1 0 1 0-1.42-1.42Zm8.58-12.08a4.49 4.49 0 0 0-6.33 0l-3.89 3.88a1 1 0 0 0 1.42 1.42l3.88-3.88a2.52 2.52 0 0 1 3.5 0 2.47 2.47 0 0 1 0 3.5l-3.88 3.88a1 1 0 1 0 1.42 1.42l3.88-3.89a4.49 4.49 0 0 0 0-6.33ZM8.83 15.17a1 1 0 0 0 1.1.22 1 1 0 0 0 .32-.22l4.92-4.92a1 1 0 0 0-1.42-1.42l-4.92 4.92a1 1 0 0 0 0 1.42Z"/></svg></a>
  </summary>
  <div class="faq-answer">
    <slot />
  </div>
</details>

<script>
  function openHashTarget() {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    const target = document.getElementById(hash);
    if (target instanceof HTMLDetailsElement && target.classList.contains("faq-item")) {
      target.open = true;
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  }

  function initFaqAnchors() {
    document.querySelectorAll<HTMLAnchorElement>(".faq-item .faq-anchor").forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        e.stopPropagation();
      });
    });
  }

  function populateToc() {
    const toc = document.querySelector("snake-toc nav > ul");
    if (!toc) return;

    const faqItems = document.querySelectorAll<HTMLDetailsElement>(".faq-item");
    if (faqItems.length === 0) return;

    // Group FAQ items by their preceding h2 section
    const sections = new Map<string, HTMLDetailsElement[]>();
    for (const item of faqItems) {
      // Walk backwards through siblings to find the parent h2
      let el: Element | null = item;
      let sectionId = "";
      while (el) {
        el = el.previousElementSibling;
        if (!el) break;
        // Starlight wraps h2 in .sl-heading-wrapper
        const heading = el.matches(".sl-heading-wrapper")
          ? el.querySelector("h2")
          : el.matches("h2") ? el : null;
        if (heading) {
          sectionId = heading.id;
          break;
        }
      }
      if (!sectionId) continue;
      if (!sections.has(sectionId)) sections.set(sectionId, []);
      sections.get(sectionId)!.push(item);
    }

    // Inject TOC entries under each section
    for (const [sectionId, items] of sections) {
      const sectionLink = toc.querySelector<HTMLAnchorElement>(`a[href="#${sectionId}"]`);
      if (!sectionLink) continue;
      const sectionLi = sectionLink.closest("li");
      if (!sectionLi) continue;

      // Clone structure from existing TOC entries
      const refLi = sectionLi;
      const refA = refLi.querySelector(":scope > a");
      if (!refA) continue;

      const subUl = document.createElement("ul");
      // Copy classes and depth style from the parent ul
      const parentUl = refLi.parentElement;
      if (parentUl) {
        subUl.className = parentUl.className;
        subUl.style.setProperty("--depth", "1");
      }

      for (const item of items) {
        const summary = item.querySelector("summary strong");
        if (!summary) continue;

        const li = document.createElement("li");
        li.className = refLi.className;
        li.style.setProperty("--depth", "1");

        const a = document.createElement("a");
        a.href = `#${item.id}`;
        a.className = refA.className;
        a.style.setProperty("--depth", "1");

        const span = document.createElement("span");
        span.className = refA.querySelector("span")?.className ?? "";
        span.style.setProperty("--depth", "1");
        span.textContent = summary.textContent;

        a.appendChild(span);
        li.appendChild(a);
        subUl.appendChild(li);
      }
      sectionLi.appendChild(subUl);
    }

    document.dispatchEvent(new CustomEvent("faq-toc-ready"));
  }

  openHashTarget();
  initFaqAnchors();
  populateToc();
  window.addEventListener("hashchange", openHashTarget);
  document.addEventListener("astro:page-load", () => {
    openHashTarget();
    initFaqAnchors();
    populateToc();
  });
</script>
